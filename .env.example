# ── Backend ─────────────────────────────────────────────────────
APP_SECRET=               # Application secret (used for JWT signing)

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=             # MySQL connection string (mysql://user:pass@host:port/db)

# ── Google Auth ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=         # Google OAuth client ID
GOOGLE_CLIENT_SECRET=     # Google OAuth client secret
VITE_GOOGLE_CLIENT_ID=    # Same Google OAuth client ID, exposed to the browser

# ── Admin Role ──────────────────────────────────────────────────
OWNER_UNION_ID=           # Union ID of the app creator; this user gets role "admin" on first login

# ── Source Ingestion (Optional) ─────────────────────────────────
X_BEARER_TOKEN=           # X API bearer token for recent search ingestion
LINKEDIN_ACCESS_TOKEN=    # LinkedIn access token, only if approved API access exists
XHS_PROVIDER_API_KEY=     # Xiaohongshu/RedNote provider key, if using an authorized provider
XHS_PROVIDER_BASE_URL=    # Xiaohongshu/RedNote provider base URL
INGESTION_ADMIN_SECRET=   # Optional secret for protected ingestion jobs

# ── AI Moderation (Optional) ────────────────────────────────────
OPENAI_API_KEY=           # OpenAI API key for AI post moderation
OPENAI_MODERATION_MODEL=gpt-5.4-mini # Cost-conscious default for structured moderation decisions
