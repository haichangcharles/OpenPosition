{
  "version": 2,
  "buildCommand": "npm run db:migrate && npm run build",
  "outputDirectory": "dist/public",
  "functions": {
    "api/boot.ts": {
      "maxDuration": 10
    }
  },
  "crons": [
    {
      "path": "/api/cron/keepalive",
      "schedule": "0 8 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/boot.ts"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
