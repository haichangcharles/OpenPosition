{
  "version": 2,
  "buildCommand": "npm run db:migrate && npm run build",
  "outputDirectory": "dist/public",
  "functions": {
    "api/boot.ts": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/boot.ts"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
